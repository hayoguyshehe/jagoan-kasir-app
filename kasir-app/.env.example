# Kasir App Environment Variables (.env.local)
# Copy this file to .env.local and fill in your values

# InsForge Config
VITE_INSFORGE_URL=https://YOUR_PROJECT.ap-southeast.insforge.app
VITE_INSFORGE_ANON_KEY=anon_YOUR_KEY_HERE

# Brand Configuration
VITE_BRAND_SLUG=2trees
VITE_BRAND_NAME="2 Trees Coffee"
VITE_PRIMARY_COLOR="#0B403A"
VITE_LOGO_URL="/brands/2trees/logo.svg"
VITE_LOGIN_BG_IMAGE="https://images.unsplash.com/photo-1554118811-1e0d58224f24?q=80&w=2047&auto=format&fit=crop"
