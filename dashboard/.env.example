# Dashboard Environment Variables (.env.local)
# Copy this file to .env.local and fill in your values

# InsForge Config
NEXT_PUBLIC_INSFORGE_URL=https://YOUR_PROJECT.ap-southeast.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=anon_YOUR_KEY_HERE

# Brand Configuration
NEXT_PUBLIC_BRAND_SLUG=2trees
NEXT_PUBLIC_BRAND_NAME="2 Trees Coffee"
NEXT_PUBLIC_PRIMARY_COLOR="#0B403A"
NEXT_PUBLIC_LOGO_URL="/brands/2trees/logo.svg"
