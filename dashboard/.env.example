# Dashboard Environment Variables (.env.local)
# Copy this file to .env.local and fill in your values

# InsForge Config
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.ap-southeast.supabase.app
NEXT_PUBLIC_SUPABASE_ANON_KEY=anon_YOUR_KEY_HERE

# Brand Configuration
NEXT_PUBLIC_BRAND_SLUG=2trees
NEXT_PUBLIC_BRAND_NAME="2 Trees Coffee"
NEXT_PUBLIC_PRIMARY_COLOR="#0B403A"
NEXT_PUBLIC_LOGO_URL="/brands/2trees/logo.svg"
NEXT_PUBLIC_LOGIN_BG_IMAGE="https://images.unsplash.com/photo-1502086223501-7ea6ecd79368?q=80&w=2038&auto=format&fit=crop"
